# ═══════════════════════════════════════════════════════════
# ReconBase — Variables de entorno
# Copia este archivo a .env en local, o configura en Railway.
# ═══════════════════════════════════════════════════════════

# ── OBLIGATORIAS EN PRODUCCIÓN ──
SECRET_KEY=cambia_esto_por_una_cadena_aleatoria_larga
DATABASE_URL=postgresql://user:pass@host:5432/dbname
BASE_URL=https://tudominio.com

# ── STRIPE (para cobros Pro) ──
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_PRO=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── EMAIL ──
# Opción A: Resend (recomendado, vía HTTPS API)
RESEND_API_KEY=re_...
# Opción B: SMTP (Gmail como fallback). Usa una app-password, no tu contraseña.
MAIL_USER=tu_email@gmail.com
MAIL_PASS=xxxx xxxx xxxx xxxx
MAIL_FROM=ReconBase <noreply@tudominio.com>

# ── OPCIONALES ──
# Sentry para tracking de errores
SENTRY_DSN=
# API interna (si quieres exponer /api/v1/scan a clientes)
RECONBASE_API_KEY=
# Analytics
GA_ID=
PLAUSIBLE_DOMAIN=
